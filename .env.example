# Flightdeck runtime data. Keep this outside the git repo for portable installs.
FLIGHTDECK_DATA_DIR=/home/flightdeck/flightdeck-data

# Optional footer/runtime display. Leave blank on Raspberry Pi installs to
# auto-detect the model and memory, e.g. "running on Pi 5 8GB".
# FLIGHTDECK_INSTANCE_NAME=Pi 5 8GB
# FLIGHTDECK_HOST_ADDRESS=192.168.4.127

# Optional explicit overrides. Usually leave these commented and let DATA_DIR decide.
# FLIGHTDECK_DB_PATH=/home/flightdeck/flightdeck-data/flightdeck.db
# FLIGHTDECK_UPLOADS_DIR=/home/flightdeck/flightdeck-data/uploads
# FLIGHTDECK_PRINTERS_CONFIG=/home/flightdeck/flightdeck-data/printers.yaml
# FLIGHTDECK_PRINT_LIBRARY=/home/flightdeck/flightdeck-data/print_library
